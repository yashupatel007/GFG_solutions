class Solution {
  public:
    vector<int> bellmanFord(int V, vector<vector<int>>& edges, int src) {
        // Code here
        int e=edges.size();
        vector<int>dist(V,1e8);
        dist[src]=0;
        
        for(int i=0;i<V-1;i++)
        {
            bool flag=0;
            
            for(int j=0;j<e;j++)
            {
                int u=edges[j][0];
                int v=edges[j][1];
                int w=edges[j][2];
                
                if(dist[u]==1e8)
                    continue;
                if(dist[u]+w<dist[v])
                {
                    flag=1;
                    dist[v]=dist[u]+w;
                    
                }
              
            }
              if(!flag)
                return dist;
           
        }
        
        // for cycle detection
        
         for(int j=0;j<e;j++)
            {
                int u=edges[j][0];
                int v=edges[j][1];
                int w=edges[j][2];
                
                
                if(dist[u]+w<dist[v])
                {
                    vector<int>ans;
                    ans.push_back(-1);
                    return ans;
                }
            }
            return dist;
        
    }
};
