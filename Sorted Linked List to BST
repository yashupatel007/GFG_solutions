class Solution {
  public:
    //logic to make balanced BST
    TNode* BST(vector<int>& nodes,int start,int end)
    {
        if(start>end)
            return NULL;
        int mid=start+(end-start+1)/2;
        TNode* root=new TNode(nodes[mid]);
        root->left=BST(nodes,start,mid-1);
        root->right=BST(nodes,mid+1,end);
        return root;
    }
    TNode *sortedListToBST(LNode *head) {
        // code here
        vector<int>nodes;
        while(head) //convert LL into array
        {
            nodes.push_back(head->data);
            head=head->next;
        }
        return BST(nodes,0,nodes.size()-1);
    }
};
