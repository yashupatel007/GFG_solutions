class Solution {
https://www.geeksforgeeks.org/problems/level-order-traversal/1?page=1&difficulty%5B%5D=0&category%5B%5D=Tree&sortBy=submissions

public:
    vector<vector<int>> levelOrder(Node *root) {
        // code here
        queue<Node*>q;
        vector<vector<int>>ans;
       
        q.push(root);
        
        while(!q.empty())
        {
            vector<int>res;
            int s=q.size();
            while(s--)
            {
                Node* temp;
                temp=q.front();
                q.pop();
                res.push_back(temp->data);
            if(temp->left!=NULL)
                q.push(temp->left);
            
            if(temp->right!=NULL)
                q.push(temp->right);
            }
            ans.push_back(res);
        }
        return ans;
    }
};
