class Solution {
  public:
    int assignHole(vector<int>& mices, vector<int>& holes) {
        // code here
        int n=holes.size();
        sort(mices.begin(),mices.end());
        sort(holes.begin(),holes.end());
        
        int mini=INT_MIN;
        for(int i=0;i<n;i++)
        {
            mini=max(mini,abs(mices[i]-holes[i]));
        }
        return mini;
    }
};
